# ============================================================
# ENV VARIABLES — Talleres Santa Eulalia Bot
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# WhatsApp Cloud API (Meta)
# https://developers.facebook.com/docs/whatsapp/cloud-api
# ------------------------------------------------------------

# Permanent or temporary access token from Meta App Dashboard
WHATSAPP_TOKEN=

# Phone Number ID from WhatsApp > Getting Started in Meta Dashboard
WHATSAPP_PHONE_NUMBER_ID=

# WhatsApp Business Account ID (WABA ID)
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Arbitrary secret token you set when registering the webhook in Meta Dashboard.
# The webhook handler uses it to verify incoming requests.
WHATSAPP_VERIFY_TOKEN=

# ------------------------------------------------------------
# Supabase
# https://supabase.com/dashboard/project/<project>/settings/api
# ------------------------------------------------------------

# Project API URL (public)
SUPABASE_URL=

# Anon / public key — safe for client-side use (RLS enforced)
SUPABASE_ANON_KEY=

# Service role key — bypasses RLS; ONLY used in server-side code
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# OpenAI
# Used ONLY for entity extraction (NLP), never for decisions.
# ------------------------------------------------------------

OPENAI_API_KEY=

# Model to use for entity extraction (e.g. gpt-4o-mini)
OPENAI_ENTITY_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Public URL of this deployment (used to build absolute webhook URLs)
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Secret used to sign internal API calls between Next.js routes
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# ------------------------------------------------------------
# Chatwoot (human handoff inbox)
# https://www.chatwoot.com/docs/self-hosted/configuration/environment-variables
# ------------------------------------------------------------

# Full URL of your Chatwoot instance (no trailing slash)
# e.g. https://app.chatwoot.com  or  https://chatwoot.yourdomain.com
CHATWOOT_BASE_URL=

# API access token — generate in Chatwoot > Profile Settings > Access Token
CHATWOOT_API_TOKEN=

# Numeric ID of the Chatwoot account (visible in the URL: /app/accounts/<id>)
CHATWOOT_ACCOUNT_ID=

# ID of the WhatsApp inbox inside Chatwoot (Settings > Inboxes > <inbox> > Settings > ID)
CHATWOOT_INBOX_ID=

# Arbitrary secret to validate incoming Chatwoot webhook calls.
# Set the same value in Chatwoot > Settings > Integrations > Webhooks > Token.
# Generate with: openssl rand -hex 32
CHATWOOT_WEBHOOK_TOKEN=

# ------------------------------------------------------------
# Optional — feature flags
# ------------------------------------------------------------

# Set to "true" to enable verbose state-machine logging in the console
DEBUG_STATE_MACHINE=false

# Set to "true" to reply to all messages with a static echo (smoke-test mode)
ECHO_MODE=false
